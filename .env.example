# OpenAI API Configuration
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-api-key-here

# Chatbot Configuration
# Name of your chatbot
CHATBOT_NAME=AI Assistant

# OpenAI Model to use
# Options: gpt-3.5-turbo, gpt-4, gpt-4-turbo-preview
MODEL_NAME=gpt-3.5-turbo

# Temperature controls randomness/creativity (0-2)
# 0 = deterministic, 1 = balanced, 2 = very creative
TEMPERATURE=0.7

# Maximum tokens in response
MAX_TOKENS=2000

# System prompt/personality for the chatbot
SYSTEM_PROMPT=You are a helpful AI assistant that responds to user queries in a friendly and informative manner.

# Application Settings
# Port for the application (if applicable)
PORT=8501

# Debug mode (true or false)
DEBUG=false

# Language preference (en or ar)
LANGUAGE=en
